# Copy this file to .env and fill in values before running docker-compose.

# Set to "production" to use Anthropic Claude; "local" to use LM Studio / vLLM.
ENV=local

# Required in production mode.
ANTHROPIC_API_KEY=

# Local LLM endpoint (LM Studio default). Ignored in production.
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=local-model

# HyperDX — UI at :8080, OTLP ingestion at :4318.
HYPERDX_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Langfuse — local instance at :3000.
LANGFUSE_PUBLIC_KEY=publickey-local
LANGFUSE_SECRET_KEY=secretkey-local
LANGFUSE_HOST=http://localhost:3000
